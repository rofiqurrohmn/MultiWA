{
  "name": "multiwa",
  "version": "1.0.0",
  "private": true,
  "description": "Open Source WhatsApp Business API Gateway - Multi-engine, Self-hosted, Enterprise-ready",
  "keywords": [
    "whatsapp",
    "api",
    "gateway",
    "baileys",
    "whatsapp-web-js",
    "self-hosted",
    "open-source",
    "multiwa"
  ],
  "homepage": "https://github.com/ribato22/multiwa",
  "repository": {
