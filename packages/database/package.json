{
  "name": "@multiwa/database",
  "version": "1.0.0",
  "private": true,
  "description": "MultiWA Database Layer (Prisma)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
