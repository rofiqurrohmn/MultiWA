    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "dotenv": "^17.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.3.0",
    "typescript": "^5.7.0"
  }
}